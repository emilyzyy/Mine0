CEREBRAS_API_KEY=replace-me
CEREBRAS_MODEL=gemma-4-31b
CEREBRAS_FALLBACK_MODEL=gpt-oss-120b
# Set to 1 after placing real Minecraft screenshots in MINE0_SCREENSHOT_DIR.
CEREBRAS_ENABLE_IMAGE_INPUT=1
MINE0_SCREENSHOT_DIR=sample_data/minecraft_frames
MINE0_PLANNER_AGENTS=3
MINE0_ROLLOUT_TARGET=5
MINE0_TEMPERATURE=0.2
MINE0_MAX_OUTPUT_TOKENS=1400
MINE0_MAX_DECISION_STEPS=6

# Mineflayer live runtime. Leave disabled to keep using the mock world.
MINE0_MINEFLAYER_ENABLED=0
MINE0_MINEFLAYER_HOST=127.0.0.1
MINE0_MINEFLAYER_PORT=25565
MINE0_MINEFLAYER_USERNAME=Mine0Bot
MINE0_MINEFLAYER_PASSWORD=
MINE0_MINEFLAYER_AUTH=offline
MINE0_MINEFLAYER_VERSION=1.21.1
MINE0_MINEFLAYER_CONNECT_TIMEOUT_MS=20000
MINE0_MINEFLAYER_ACTION_TIMEOUT_MS=25000
MINE0_MINEFLAYER_VIEWER_ENABLED=0
MINE0_MINEFLAYER_VIEWER_PORT=3007
MINE0_MINEFLAYER_VIEWER_FIRST_PERSON=1

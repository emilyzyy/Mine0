CEREBRAS_API_KEY=replace-me
CEREBRAS_MODEL=gemma-4-31b
CEREBRAS_FALLBACK_MODEL=gpt-oss-120b
# Set to 1 after placing real Minecraft screenshots in MINE0_SCREENSHOT_DIR.
CEREBRAS_ENABLE_IMAGE_INPUT=1
MINE0_SCREENSHOT_DIR=sample_data/minecraft_frames
MINE0_PLANNER_AGENTS=3
MINE0_ROLLOUT_TARGET=5
MINE0_TEMPERATURE=0.2
MINE0_MAX_OUTPUT_TOKENS=1400

# --- JARVIS-VLA remote executor (RunPod SSH bridge) ---
# SSH connection to the RunPod pod running MineStudio + JARVIS.
# The vLLM server must already be running on port 8000 before invoking npm run jarvis.
RUNPOD_HOST=194.68.245.71
RUNPOD_PORT=22072
RUNPOD_USER=root
RUNPOD_KEY_PATH=~/.ssh/id_ed25519
# Path to the JarvisVLA repository on the remote host.
JARVIS_REMOTE_REPO=/workspace/JarvisVLA
# vLLM base URL as seen from inside the remote host (loopback).
JARVIS_BASE_URL=http://127.0.0.1:8000/v1
# HuggingFace checkpoint identifier for the JARVIS model.
JARVIS_CHECKPOINTS=CraftJarvis/JarvisVLA-Qwen2-VL-7B
# MineStudio env-config path (relative to the envs/ directory inside JarvisVLA).
JARVIS_ENV_CONFIG=kill/kill_zombie
# Maximum number of Minecraft frames to run per evaluation episode.
JARVIS_MAX_FRAMES=2
# Sampling temperature for JARVIS action generation.
JARVIS_TEMPERATURE=0.01
# Remote directory where episode videos are saved.
JARVIS_VIDEO_FOLD=logs/tiny
